{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Invoice Extraction Schema",
  "description": "Validated output schema for Indian invoice/bill extraction. Covers GST invoices, proforma invoices, and general commercial invoices.",
  "type": "object",
  "required": ["invoice_number", "vendor_name", "invoice_date", "total_amount"],
  "properties": {
    "invoice_number": {
      "type": "string",
      "description": "Unique invoice identifier",
      "minLength": 1,
      "maxLength": 50
    },
    "vendor_name": {
      "type": "string",
      "description": "Name of the vendor/seller",
      "minLength": 2,
      "maxLength": 200
    },
    "vendor_gstin": {
      "type": ["string", "null"],
      "description": "Vendor's GSTIN (15-character alphanumeric)",
      "pattern": "^\\d{2}[A-Z]{5}\\d{4}[A-Z]{1}[A-Z\\d]{1}[Z]{1}[A-Z\\d]{1}$"
    },
    "buyer_name": {
      "type": ["string", "null"],
      "description": "Name of the buyer/purchaser"
    },
    "buyer_gstin": {
      "type": ["string", "null"],
      "description": "Buyer's GSTIN if present",
      "pattern": "^\\d{2}[A-Z]{5}\\d{4}[A-Z]{1}[A-Z\\d]{1}[Z]{1}[A-Z\\d]{1}$"
    },
    "invoice_date": {
      "type": "string",
      "description": "Invoice date in DD/MM/YYYY format",
      "pattern": "^\\d{2}/\\d{2}/\\d{4}$"
    },
    "due_date": {
      "type": ["string", "null"],
      "description": "Payment due date in DD/MM/YYYY format",
      "pattern": "^\\d{2}/\\d{2}/\\d{4}$"
    },
    "line_items": {
      "type": "array",
      "description": "List of line items on the invoice",
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price", "amount"],
        "properties": {
          "description": {
            "type": "string",
            "description": "Item description"
          },
          "hsn_code": {
            "type": ["string", "null"],
            "description": "HSN/SAC code for GST classification"
          },
          "quantity": {
            "type": "number",
            "description": "Quantity of items",
            "minimum": 0
          },
          "unit_price": {
            "type": "number",
            "description": "Price per unit in INR",
            "minimum": 0
          },
          "amount": {
            "type": "number",
            "description": "Line item total (quantity × unit_price)",
            "minimum": 0
          }
        }
      }
    },
    "subtotal": {
      "type": ["number", "null"],
      "description": "Sum of all line item amounts before tax",
      "minimum": 0
    },
    "cgst_amount": {
      "type": ["number", "null"],
      "description": "Central GST amount in INR",
      "minimum": 0
    },
    "sgst_amount": {
      "type": ["number", "null"],
      "description": "State GST amount in INR",
      "minimum": 0
    },
    "igst_amount": {
      "type": ["number", "null"],
      "description": "Integrated GST amount in INR (for inter-state transactions)",
      "minimum": 0
    },
    "total_tax": {
      "type": ["number", "null"],
      "description": "Total tax amount (CGST + SGST or IGST)",
      "minimum": 0
    },
    "total_amount": {
      "type": "number",
      "description": "Grand total amount including taxes in INR",
      "minimum": 0,
      "maximum": 1000000000
    },
    "amount_in_words": {
      "type": ["string", "null"],
      "description": "Total amount written in words (common on Indian invoices)"
    },
    "place_of_supply": {
      "type": ["string", "null"],
      "description": "Place of supply for GST determination"
    },
    "payment_terms": {
      "type": ["string", "null"],
      "description": "Payment terms (e.g., Net 30, COD)"
    }
  },
  "additionalProperties": false
}
