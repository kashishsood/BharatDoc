{
  "dashboard": {
    "title": "BharatDoc-VLM - Document Intelligence",
    "uid": "bharatdoc-vlm",
    "timezone": "Asia/Kolkata",
    "refresh": "10s",
    "panels": [
      {
        "title": "Request Latency (p50/p95/p99)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(request_latency_seconds_bucket[5m]))", "legendFormat": "p50"},
          {"expr": "histogram_quantile(0.95, rate(request_latency_seconds_bucket[5m]))", "legendFormat": "p95"},
          {"expr": "histogram_quantile(0.99, rate(request_latency_seconds_bucket[5m]))", "legendFormat": "p99"}
        ],
        "yAxes": [{"label": "Latency (s)", "format": "s"}]
      },
      {
        "title": "Requests per Second by Doc Type",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {"expr": "rate(requests_total[5m])", "legendFormat": "{{doc_type}} ({{status}})"}
        ]
      },
      {
        "title": "Prediction Confidence",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
        "targets": [
          {"expr": "prediction_confidence", "legendFormat": "{{doc_type}}"}
        ],
        "fieldConfig": {"defaults": {"min": 0, "max": 1, "thresholds": {"steps": [
          {"value": 0, "color": "red"},
          {"value": 0.6, "color": "yellow"},
          {"value": 0.8, "color": "green"}
        ]}}}
      },
      {
        "title": "Error Rate",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
        "targets": [
          {"expr": "rate(requests_total{status='error'}[5m]) / rate(requests_total[5m]) * 100", "legendFormat": "Error %"}
        ],
        "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"steps": [
          {"value": 0, "color": "green"},
          {"value": 2, "color": "yellow"},
          {"value": 5, "color": "red"}
        ]}}}
      },
      {
        "title": "Validation Errors",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
        "targets": [
          {"expr": "rate(validation_errors_total[5m])", "legendFormat": "{{doc_type}}"}
        ]
      },
      {
        "title": "Circuit Breaker State",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 14},
        "description": "Current circuit breaker state: closed (normal), open (fallback), half-open (testing)"
      },
      {
        "title": "Throughput (req/s)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 14},
        "targets": [
          {"expr": "sum(rate(requests_total[1m]))", "legendFormat": "Total RPS"}
        ]
      }
    ]
  }
}
